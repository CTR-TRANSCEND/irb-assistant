APP_NAME="IRB Assistant"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_SOCKET=var/mariadb/run/mysqld.sock
DB_DATABASE=irb_503c_assistant
DB_USERNAME=irb503c
DB_PASSWORD=

# Initial admin user created by `php artisan db:seed`.
ADMIN_NAME="Admin"
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD="change-me"

# LLM provider configuration is managed in the Admin UI.
# This env file only contains *bootstrapping defaults*.
IRB_ALLOW_EXTERNAL_LLM=false

# SPEC-LLM-001 REQ-LLM-009: Local-dev only — permits 127.0.0.1 / 0.0.0.0 / ::1 /
# IPv4-mapped-loopback in BaseUrlValidator. NEVER set true in production.
# RFC1918, link-local, ULA, 6to4, and Teredo remain rejected even when this is on.
IRB_ALLOW_LLM_LOOPBACK=false

IRB_RETENTION_DAYS=14
IRB_MAX_UPLOAD_BYTES=104857600
IRB_PDF_PARSER_MEMORY_MB=256

# PDF extraction settings
IRB_PDFTOTEXT_TIMEOUT_SECONDS=20
IRB_PDF_MAX_PAGES=200
IRB_PDF_MAX_TEXT_BYTES=5242880

# LLM analysis settings
IRB_ANALYSIS_BATCH_SIZE=20
IRB_MAX_CHUNKS_SENT=40
IRB_MAX_CHUNK_CHARS_SENT=1200

IRB_FILE_ENCRYPTION_KEYS=
IRB_FILE_ENCRYPTION_ACTIVE_KEY_ID=
IRB_DB_PAYLOAD_ENC_KEY_ID=

# SPEC-IRB-GUIDE-001 REQ-IRB-GUIDE-030: maximum number of missing fields drafted per analysis run
# in assistant mode. Bounds worst-case token spend and wall-clock time.
# Drafting stops early when exceeded; a 'project.field.ai_drafting_truncated' audit event is emitted.
IRB_DRAFTING_MAX_PER_RUN=20

# LlmChatService HTTP timeout (seconds). Sized for 20B reasoning models
# (gpt-oss-20b, DeepSeek-R1) on multi-field batches — chain-of-thought +
# JSON emission can run 2-4 minutes on a slow GPU. Apache vhost ProxyTimeout
# and PHP-FPM request_terminate_timeout MUST be ≥ this value to avoid
# 504 Gateway Timeout.
IRB_LLM_CHAT_TIMEOUT_SECONDS=600

SESSION_DRIVER=database
# SESSION_LIFETIME = idle-timeout in minutes. Activity refreshes the timer.
# 60 matches IRB/HIPAA-style hardened posture for PII-handling apps.
SESSION_LIFETIME=60
# SESSION_EXPIRE_ON_CLOSE=true invalidates the session cookie when the browser
# closes, even before SESSION_LIFETIME elapses. Combined with no Remember Me on
# the login form, this guarantees no persistent auth across browser sessions.
SESSION_EXPIRE_ON_CLOSE=true
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# PRODUCTION: Set both to true when serving over HTTPS.
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
