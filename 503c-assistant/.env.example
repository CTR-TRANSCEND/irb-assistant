APP_NAME="503c Assistant"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_SOCKET=var/mariadb/run/mysqld.sock
DB_DATABASE=irb_503c_assistant
DB_USERNAME=irb503c
DB_PASSWORD=

# Initial admin user created by `php artisan db:seed`.
ADMIN_NAME="Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD="change-me"

# Set to true to allow public user registration (default: false).
IRB_ALLOW_REGISTRATION=false

# LLM provider configuration is managed in the Admin UI.
# This env file only contains *bootstrapping defaults*.
IRB_ALLOW_EXTERNAL_LLM=false
IRB_RETENTION_DAYS=14
IRB_MAX_UPLOAD_BYTES=104857600
IRB_PDF_PARSER_MEMORY_MB=256

# PDF extraction settings
IRB_PDFTOTEXT_TIMEOUT_SECONDS=20
IRB_PDF_MAX_PAGES=200
IRB_PDF_MAX_TEXT_BYTES=5242880

# LLM analysis settings
IRB_ANALYSIS_BATCH_SIZE=20
IRB_MAX_CHUNKS_SENT=40
IRB_MAX_CHUNK_CHARS_SENT=1200

IRB_FILE_ENCRYPTION_KEYS=
IRB_FILE_ENCRYPTION_ACTIVE_KEY_ID=
IRB_DB_PAYLOAD_ENC_KEY_ID=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# PRODUCTION: Set both to true when serving over HTTPS.
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
